{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "declaration": true,
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "./src/squirrel-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["react"]
  },
  "include": ["src"]
}
